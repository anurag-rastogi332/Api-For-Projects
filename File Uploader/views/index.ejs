
     <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #ff7e5f, #feb47b);
            color: #ffffff;
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            flex-direction: column;
        }
    
        .container {
            background: #fff;
            padding: 40px 30px;
            border-radius: 15px;
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);
            text-align: center;
            max-width: 500px;
            width: 100%;
            animation: fadeIn 1.2s ease-in-out;
        }
    
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }
    
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    
        h1 {
            font-size: 36px;
            margin-bottom: 20px;
            background: linear-gradient(90deg, #ff7e5f, #feb47b);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-top: 0;
        }
    
        .form-group {
            width: 100%;
            margin-bottom: 20px;
        }
    
        input[type="file"] {
            padding: 10px;
            border: none;
            border-radius: 12px;
            background: linear-gradient(145deg, #ff6a00, #ffcc00);
            color: white;
            font-size: 15px;
            cursor: pointer;
            width: 90%;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
    
        input[type="file"]:hover {
            transform: scale(1.05);
            box-shadow: 0 0 15px rgba(255, 105, 180, 0.7);
        }
    
        input[type="submit"] {
            padding: 12px 30px;
            background: linear-gradient(135deg, #ff7e5f, #feb47b);
            color: white;
            font-size: 18px;
            font-weight: 600;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            width: 90%;
            margin-top: 15px;
        }
    
        input[type="submit"]:hover {
            transform: scale(1.05);
            box-shadow: 0 0 20px rgba(255, 182, 193, 0.8);
        }
    
        #uploaded-image-container {
            margin-top: 30px;
            width: 100%;
            display: flex;
            justify-content: center;
            flex-direction: column;
            align-items: center;
            color: black;
        }
    
        img {
            width: 100%;
            height: auto;
            max-width: 300px;
            max-height: 300px;
            border-radius: 10px;
            border: 1px solid blue;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
        }
    
        @media (max-width: 600px) {
            .container {
                padding: 30px 20px;
                width: 90%;
            }
    
            h1 {
                font-size: 28px;
            }
    
            input[type="file"],
            input[type="submit"] {
                font-size: 16px;
                padding: 12px;
            }
        }
    </style>



<body>
    <!-- Main wrapper container -->
    <div class="container">

        <!-- 🔽 Form शुरू होता है: यह वह बॉक्स है जिसमें user image upload करेगा -->
        <!-- 
            action="" → form को submit करने पर डेटा कहाँ भेजना है, वह URL यहाँ लिखा जाता है
                        अभी खाली है, यानी यह current route पर ही submit होगा
            method="post" → POST method उपयोग होती है जब डेटा को server पर भेजना हो (secure तरीके से)
            enctype="multipart/form-data" → जरूरी होता है जब हम फ़ाइल भेज रहे होते हैं, वरना फ़ाइल भेजी नहीं जाती
        -->
        <form action="/upload" method="post" enctype="multipart/form-data">

            <!-- 📁 फ़ाइल इनपुट field -->
            <div class="form-group">
                <!-- 
                    input type="file" → यह user को किसी image (या कोई भी file) चुनने देता है
                    name="file" → backend में file को इसी नाम से access किया जाएगा
                    id="file-input" → इस इनपुट को JS या CSS से access करने के लिए
                -->
                <input type="file" name="file" id="file-input">
            </div>

            <!-- 🚀 Submit बटन -->
            <div class="form-group">
                <!-- 
                    यह बटन form को submit करता है, जिससे image upload प्रक्रिया शुरू होती है
                    value="upload" → बटन पर दिखने वाला text
                -->
                <input type="submit" value="upload">
            </div>

            <!-- ✅ Uploaded image दिखाने के लिए जगह -->
            <div id="uploaded-image-contentner">
                <!-- 
                    <% if(url){ %> ... <% } %> 
                    यह EJS (Embedded JavaScript) का syntax है जो Express JS के साथ यूज़ होता है
                    यह चेक करता है कि अगर backend ने एक valid image URL भेजा है, 
                    तो image और success message दिखाया जाए
                -->
                <% if(url){ %>

                    <!-- ✅ Upload success message -->
                    <h2>file uploaded successfully</h2>

                    <!-- 🖼️ अपलोड की गई इमेज को दिखाना -->
                    <!-- 
                        src="<%= url %>" → EJS में `url` variable के अंदर जो image path है, उसे यहाँ डाला जाएगा
                        alt="uploaded image" → SEO और accessibility के लिए जरूरी
                    -->
                    <img src="<%= url %>" alt="uploaded image">

                <% } %>
            </div>

        </form> <!-- 🔚 form खत्म -->

    </div> <!-- 🔚 container खत्म -->

</body>
