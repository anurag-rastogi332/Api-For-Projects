<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register</title>

  <style>
    /* ===== Global Reset ===== */
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    /* ===== Body Styling ===== */
    body {
      font-family: 'Poppins', sans-serif;
      background: linear-gradient(135deg, #667eea, #764ba2);
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      padding: 20px;
    }

    /* ===== Container Card ===== */
    .container {
      background: #fff;
      padding: 50px 40px;
      border-radius: 20px;
      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
      width: 100%;
      max-width: 420px;
      transition: all 0.3s ease;
      animation: fadeIn 0.8s ease;
    }

    .container:hover {
      transform: translateY(-5px);
    }

    /* ===== Heading ===== */
    h2 {
      text-align: center;
      margin-bottom: 35px;
      color: #5e2ced;
      font-weight: 700;
      letter-spacing: 1px;
    }

    /* ===== Input Fields ===== */
    input {
      padding: 15px 18px;
      margin-bottom: 20px;
      border-radius: 12px;
      border: 2px solid #e0e0e0;
      font-size: 1em;
      width: 100%;
      transition: 0.3s;
      background: #fafafa;
    }

    input:focus {
      outline: none;
      border-color: #5e2ced;
      background: #fff;
      box-shadow: 0 0 10px rgba(94, 44, 237, 0.2);
    }

    /* ===== Button ===== */
    button {
      padding: 15px 20px;
      border-radius: 12px;
      border: none;
      width: 100%;
      background: linear-gradient(135deg, #5e2ced, #2575fc);
      color: #fff;
      font-size: 1em;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    button:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
      background: linear-gradient(135deg, #2575fc, #5e2ced);
    }

    /* ===== Success & Error Messages ===== */
    p.error {
      color: #ff4d4d;
      text-align: center;
      margin-bottom: 15px;
      font-weight: 500;
    }

    p.success {
      color: #28a745;
      text-align: center;
      margin-bottom: 15px;
      font-weight: 500;
    }

    /* ===== Link ===== */
    a {
      text-decoration: none;
      color: #5e2ced;
      display: block;
      text-align: center;
      margin-top: 20px;
      font-size: 0.95em;
      transition: color 0.3s;
    }

    a:hover {
      color: #2575fc;
      text-decoration: underline;
    }

    /* ===== Small Animation ===== */
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* ===== Responsive Design ===== */
    @media (max-width: 480px) {
      .container {
        padding: 35px 25px;
      }
      h2 {
        font-size: 1.6em;
        margin-bottom: 25px;
      }
      input, button {
        font-size: 0.95em;
        padding: 13px 15px;
      }
    }

    @media (max-width: 350px) {
      h2 {
        font-size: 1.3em;
      }
    }
  </style>
</head>
<body>

  <div class="container">
    <h2>Create Account</h2>

    <% if(error){ %>
      <p class="error"><%= error %></p>
    <% } %>

    <% if(success){ %>
      <p class="success"><%= success %></p>
    <% } %>

    <form action="/submit" method="POST">
      <input type="text" name="name" placeholder="Full Name" value="<%= name %>" required>
      <input type="email" name="email" placeholder="Email Address" value="<%= email %>" required>
      <input type="password" name="password" placeholder="Password" required>
      <button type="submit">Register</button>
    </form>

    <a href="/login">Already have an account? Login</a>
  </div>

</body>
</html>
